# DemoGo Server 环境变量配置

# 基本配置
NODE_ENV=production
PORT=3001
HOST=127.0.0.1

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=demogo
DB_PASSWORD=
DB_NAME=demogo

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# MinIO / 本地存储
STORAGE_BACKEND=local  # local | minio
STORAGE_PATH=/opt/demogo/data

# Session
SESSION_SECRET=

# SMTP 邮件
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 运行时配置
DEMOGO_RUNTIME_MAX_INSTANCES=1
DEMOGO_RUNTIME_MEMORY=384m
